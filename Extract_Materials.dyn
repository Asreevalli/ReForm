    {
      "ConcreteType": "CoreNodeModels.Input.StringInput, CoreNodeModels",
      "NodeType": "StringInputNode",
      "InputValue": "Extract materiial ",
      "Id": "225ff3e57ae241be80cefa8b55369399",
      "Inputs": [],
      "Outputs": [
        {
          "Id": "4f45bcd58f5146f59e3d4d1fed94c829",
          "Name": "",
