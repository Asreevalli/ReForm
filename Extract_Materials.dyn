    {
      "ConcreteType": "Dynamo.Graph.Nodes.ZeroTouch.DSFunction, DynamoCore",
      "NodeType": "FunctionNode",
      "FunctionSignature": "DSCore.List.Flatten@var[]..[],int",
      "Id": "b1eec5c9b7ef45d0ad56fc9d1fa55755",
      "Inputs": [
        {
          "Id": "0cae4aa04623412f946fc2a6e1bcb96d",
          "Name": "list",
          "Description": "List to flatten.\n\nvar[]..[]",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "47a7f96fe0804112825a130590eeb2b0",
          "Name": "amount",
          "Description": "Layers of list nesting to remove (-1 will remove all list nestings)\n\nint\nDefault value : -1",
          "UsingDefaultValue": true,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "4057ffed1c894de8b376894326e669e0",
          "Name": "list",
          "Description": "Flattened list by amount",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Auto",
      "Description": "Flattens a nested list of lists by a certain amount.\n\nList.Flatten (list: var[]..[], amount: int = -1): var[]..[]"
    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "import clr\r\n\r\n# Revit references\r\nclr.AddReference('RevitServices')\r\nfrom RevitServices.Persistence import DocumentManager\r\n\r\nclr.AddReference('RevitAPI')\r\nfrom Autodesk.Revit.DB import *\r\n\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\nelements = UnwrapElement(IN[0])\r\n\r\ndata = {}\r\n\r\n# 🔹 STRUCTURAL MATERIAL\r\ndef get_structural_material(el):\r\n    try:\r\n        p = el.LookupParameter(\"Structural Material\")\r\n        if p and p.HasValue:\r\n            return doc.GetElement(p.AsElementId())\r\n    except:\r\n        pass\r\n    return None\r\n\r\n# 🔹 DENSITY (Revit first, then default if missing)\r\ndef get_density(mat):\r\n    try:\r\n        pse = doc.GetElement(mat.StructuralAssetId)\r\n        if pse:\r\n            asset = pse.GetStructuralAsset()\r\n            if asset and asset.Density > 0:\r\n                return asset.Density * 35.3147  # convert to kg/m3\r\n    except:\r\n        pass\r\n\r\n    name = mat.Name.lower()\r\n\r\n    if \"concrete\" in name:\r\n        return 2400\r\n    elif \"brick\" in name:\r\n        return 1800\r\n    elif \"steel\" in name or \"metal\" in name:\r\n        return 7850\r\n    elif \"plaster\" in name or \"gypsum\" in name:\r\n        return 1200\r\n    elif \"insulation\" in name:\r\n        return 50\r\n    elif \"sand\" in name:\r\n        return 1600\r\n    elif \"hard\" in name:\r\n        return 2200\r\n    else:\r\n        return 1000\r\n\r\n# =====================================================\r\n# 🔹 MAIN LOOP\r\n# =====================================================\r\nfor el in elements:\r\n    try:\r\n        cat = el.Category.Name\r\n        cat_lower = cat.lower()\r\n\r\n        total_vol = 0\r\n        try:\r\n            p = el.LookupParameter(\"Volume\")\r\n            if p:\r\n                total_vol = p.AsDouble() * 0.0283168  # m3\r\n        except:\r\n            pass\r\n\r\n        # -------------------------------\r\n        # WALLS / FLOORS / ROOFS\r\n        # -------------------------------\r\n        if any(x in cat_lower for x in [\"wall\", \"floor\", \"roof\"]):\r\n            try:\r\n                type_elem = None\r\n\r\n                if \"wall\" in cat_lower:\r\n                    type_elem = el.WallType\r\n                elif \"floor\" in cat_lower:\r\n                    type_elem = el.FloorType\r\n                elif \"roof\" in cat_lower:\r\n                    type_elem = el.RoofType\r\n\r\n                cs = type_elem.GetCompoundStructure()\r\n\r\n                if cs:\r\n                    layers = cs.GetLayers()\r\n                    total_thickness = sum([l.Width for l in layers if l.Width > 0])\r\n\r\n                    for layer in layers:\r\n                        mat_id = layer.MaterialId\r\n                        if mat_id == ElementId.InvalidElementId:\r\n                            continue\r\n\r\n                        mat = doc.GetElement(mat_id)\r\n                        name = mat.Name\r\n\r\n                        frac = layer.Width / total_thickness if total_thickness > 0 else 0\r\n                        vol_m3 = total_vol * frac\r\n\r\n                        density = get_density(mat)\r\n                        mass = vol_m3 * density\r\n\r\n                        key = cat + \"|\" + name\r\n\r\n                        if key in data:\r\n                            data[key][\"volume\"] += vol_m3\r\n                            data[key][\"mass\"] += mass\r\n                        else:\r\n                            data[key] = {\r\n                                \"category\": cat,\r\n                                \"material\": name,\r\n                                \"volume\": vol_m3,\r\n                                \"density\": density,\r\n                                \"mass\": mass,\r\n                                \"count\": \"\",\r\n                                \"volume_unit\": \"m3\",\r\n                                \"density_unit\": \"kg/m3\",\r\n                                \"mass_unit\": \"kg\"\r\n                            }\r\n\r\n            except:\r\n                pass\r\n\r\n        # -------------------------------\r\n        # STRUCTURAL\r\n        # -------------------------------\r\n        elif any(x in cat_lower for x in [\"column\", \"framing\", \"beam\"]):\r\n            mat_ids = []\r\n\r\n            struct_mat = get_structural_material(el)\r\n            if struct_mat:\r\n                mat_ids = [struct_mat.Id]\r\n\r\n            if not mat_ids:\r\n                mat_ids = el.GetMaterialIds(True)\r\n\r\n            if not mat_ids:\r\n                mat_ids = el.GetMaterialIds(False)\r\n\r\n            for mid in mat_ids:\r\n                mat = doc.GetElement(mid)\r\n                name = mat.Name\r\n\r\n                vol_m3 = total_vol\r\n                density = get_density(mat)\r\n                mass = vol_m3 * density\r\n\r\n                key = cat + \"|\" + name\r\n\r\n                data[key] = {\r\n                    \"category\": cat,\r\n                    \"material\": name,\r\n                    \"volume\": vol_m3,\r\n                    \"density\": density,\r\n                    \"mass\": mass,\r\n                    \"count\": \"\",\r\n                    \"volume_unit\": \"m3\",\r\n                    \"density_unit\": \"kg/m3\",\r\n                    \"mass_unit\": \"kg\"\r\n                }\r\n\r\n        # -------------------------------\r\n        # DOORS / WINDOWS\r\n        # -------------------------------\r\n        elif \"door\" in cat_lower or \"window\" in cat_lower:\r\n            key = cat + \"|Assembly\"\r\n\r\n            if key in data:\r\n                data[key][\"count\"] += 1\r\n            else:\r\n                data[key] = {\r\n                    \"category\": cat,\r\n                    \"material\": \"Assembly\",\r\n                    \"volume\": 0,\r\n                    \"density\": 0,\r\n                    \"mass\": 0,\r\n                    \"count\": 1,\r\n                    \"volume_unit\": \"-\",\r\n                    \"density_unit\": \"-\",\r\n                    \"mass_unit\": \"-\"\r\n                }\r\n\r\n    except:\r\n        pass\r\n\r\n# =====================================================\r\n# 🔹 OUTPUT\r\n# =====================================================\r\ncategories = []\r\nmaterials = []\r\nvolumes = []\r\nvolume_units = []\r\ndensities = []\r\ndensity_units = []\r\nmasses = []\r\nmass_units = []\r\ncounts = []\r\n\r\nfor v in data.values():\r\n    categories.append(v[\"category\"])\r\n    materials.append(v[\"material\"])\r\n    volumes.append(round(v[\"volume\"], 3))\r\n    volume_units.append(v[\"volume_unit\"])\r\n    densities.append(round(v[\"density\"], 2) if isinstance(v[\"density\"], (int, float)) else v[\"density\"])\r\n    density_units.append(v[\"density_unit\"])\r\n    masses.append(round(v[\"mass\"], 2) if isinstance(v[\"mass\"], (int, float)) else v[\"mass\"])\r\n    mass_units.append(v[\"mass_unit\"])\r\n    counts.append(v[\"count\"])\r\n\r\nOUT = (\r\n    categories,\r\n    materials,\r\n    volumes,\r\n    volume_units,\r\n    densities,\r\n    density_units,\r\n    masses,\r\n    mass_units,\r\n    counts\r\n)",
      "Engine": "CPython3",
      "EngineName": "CPython3",
      "VariableInputPorts": true,
      "Id": "ae402ae0a50b4366a3024946791e5890",
      "Inputs": [
        {
          "Id": "4760be1c924941cfbccee1e23186ca30",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "2a381eb69a7d4970baf470fa9f998524",
          "Name": "OUT",
          "Description": "Result of the python script",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Runs an embedded Python script."
    },
    {
      "ConcreteType": "Dynamo.Graph.Nodes.ZeroTouch.DSFunction, DynamoCore",
      "NodeType": "FunctionNode",
      "FunctionSignature": "DSCore.List.Transpose@var[]..[]",
      "Id": "07225cdeb9574e7b947ae159a1ba8c2b",
      "Inputs": [
        {
          "Id": "6eaeb9f23d034bd3878a860b74f3d75a",
          "Name": "lists",
          "Description": "List of lists to be transposed\n\nvar[]..[]",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "ae7bcd759c9b442ab5d9af081efc6b73",
          "Name": "lists",
          "Description": "List of transposed lists",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Auto",
      "Description": "Swaps rows and columns in a list of lists. If there are some rows that are shorter than others, null values are inserted as place holders in the resultant array such that it is always rectangular.\n\nList.Transpose (lists: var[]..[]): var[]..[]"
    },
    {
      "ConcreteType": "Dynamo.Graph.Nodes.ZeroTouch.DSFunction, DynamoCore",
      "NodeType": "FunctionNode",
      "FunctionSignature": "DSOffice.Data.ExportToExcel@string,string,int,int,var[][],bool,bool",
      "Id": "41515a842b5f4272a91d729aea6d2631",
      "Inputs": [
        {
          "Id": "490c259b7a6b44328822b2c3f7f3ac6f",
          "Name": "filePath",
          "Description": "File representing the Excel workbook\n\nstring",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "2a650cd61c9c4ab8a6c9acac33f00a2f",
          "Name": "sheetName",
          "Description": "Name of the worksheet containing data\n\nstring",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "3c932208d4314769a4c936fde9390baf",
          "Name": "startRow",
          "Description": "Start row for writing data. Enter 0 for Row 1, 1 for Row 2, etc.\n\nint",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "31f11a4426464db4925d0287a2140796",
          "Name": "startColumn",
          "Description": "Start column for writing data. Enter 0 for Column A, 1 for Column B, etc.\n\nint",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "52de3e82ecd54b8691229cffa36213e4",
          "Name": "data",
          "Description": "Data to write to the spreadsheet\n\nvar[][]",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "94db1a84714046318906e17d69ca033d",
          "Name": "overWrite",
          "Description": "Toggle to clear spreadsheet before writing\n\nbool\nDefault value : false",
          "UsingDefaultValue": true,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "ec57885f053b4dffb807ee45d8e9fb82",
          "Name": "writeAsString",
          "Description": "Toggle to switch between writing Excel file as strings\n\nbool\nDefault value : false",
          "UsingDefaultValue": true,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "41c9ed7d2d0948b2830807147b821cd4",
          "Name": "data",
          "Description": "Rows of data from the Excel worksheet",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Auto",
      "Description": "Write data to a Microsoft Excel spreadsheet. Data is written by row with sublists to be written in successive rows. Rows and columns are zero-indexed; for example, the value in the data list at [0,0] will be written to cell A1. Null values and empty lists are written to Excel as empty cells. This node requires Microsoft Excel to be installed.\n\nData.ExportToExcel (filePath: string, sheetName: string, startRow: int, startColumn: int, data: var[][], overWrite: bool = false, writeAsString: bool = false): var[][]"
    },
